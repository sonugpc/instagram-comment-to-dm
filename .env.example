# App
NEXTAUTH_URL=http://localhost:3000
# Set to true locally to enable the "paste token" dev shortcut on the settings page
NEXT_PUBLIC_DEV_MODE=false
NEXTAUTH_SECRET=replace-with-a-strong-random-secret
CRON_SECRET=replace-with-a-strong-random-secret
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Database / queue
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/campaigncue
REDIS_URL=redis://localhost:6379

# Email magic links (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=CampaignCue <login@example.com>

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...

# Meta / Instagram
META_GRAPH_API_VERSION=v25.0
INSTAGRAM_APP_ID=your-instagram-app-id
INSTAGRAM_APP_SECRET=your-instagram-app-secret
FACEBOOK_APP_SECRET=your-facebook-app-secret
WEBHOOK_VERIFY_TOKEN=replace-with-a-webhook-verify-token

# DM test mode — set INSTAGRAM_TESTER_ID to a tester's Instagram IGSID.
# Use the "Test Campaign" button on the dashboard to send a preview DM to this account on demand.
INSTAGRAM_TESTER_ID=x
